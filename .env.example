# ── Copy this to .env and fill in your values ──

# PostgreSQL — use Neon free tier (neon.tech) or local install
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?ssl=require
SYNC_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Redis — use Upstash free tier (upstash.com) or local install
REDIS_URL=rediss://default:password@xxx.upstash.io:6379

# Auth (change in production)
SECRET_KEY=ubid-hackathon-secret-change-in-prod-32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Thresholds
AUTO_LINK_THRESHOLD=0.85
REVIEW_THRESHOLD=0.50

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
